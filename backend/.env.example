# AgentValue-AI 环境变量示例
# 复制为 .env 并填入实际值
#
# ┌─ 命名规范（P2-N1）────────────────────────────────────────────────────┐
# │ 1. 环境变量全部使用 SCREAMING_SNAKE_CASE（如 JWT_SECRET_KEY）。       │
# │ 2. 对应 Settings 字段为 lower_snake_case（如 jwt_secret_key）。       │
# │    pydantic-settings 不区分大小写,但项目约定统一小写做字段名。       │
# │ 3. 布尔值写 true / false（不区分大小写）。                            │
# │ 4. 列表/集合类用逗号分隔（如 CORS_ORIGINS=http://a,http://b）。       │
# │ 5. 历史兼容字段（如 OPENAI_* 兜底 CLOUD_*）保留原名,新字段统一加前缀 │
# │    业务前缀（AGENTVALUE_）或领域前缀（OCR_/ASR_/S3_）。                │
# └──────────────────────────────────────────────────────────────────────┘

# 应用配置
APP_NAME=AgentValue-AI
DEBUG=false

# 数据库（默认 SQLite，生产环境建议 PostgreSQL）
DATABASE_URL=sqlite+aiosqlite:///./agentvalue_ai.db

# 任务队列 Redis（留空则使用内存队列，单实例；配置后启用多实例共享）
# REDIS_URL=redis://redis:6379/0

# 模型档位：auto / L0 / L1 / L2 / L3
MODEL_TIER=auto

# 通用云端模型（OpenAI 兼容接口）
# 适合 DeepSeek / 阿里云百炼 / 硅基流动 等
CLOUD_API_KEY=your-cloud-api-key
CLOUD_BASE_URL=https://api.openai.com/v1
CLOUD_MODEL=gpt-4o-mini

# 兼容旧版 OpenAI 命名（未设置 cloud_* 时兜底使用）
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 本地模型（LM Studio / Ollama）
LOCAL_BASE_URL=http://localhost:1234/v1
LOCAL_API_KEY=lm-studio
LOCAL_MODEL_L1=qwen2.5-0.5b-instruct
LOCAL_MODEL_L2=qwen2.5-7b-instruct
LOCAL_MODEL_L3=qwen2.5-14b-instruct

# 多 Provider 凭证兜底（P2 深水区）
# Playground 在 tenant_provider_credentials 未配置时，按 model_name 前缀路由到对应
# Provider 类，凭证从这里兜底。生产环境推荐在管理后台 /admin/providers 配置凭证，
# 加密落库（AES-256-GCM），这里仅作为 Playground 快速联调的兜底入口。
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# GEMINI_API_KEY=your-gemini-key
# OLLAMA_BASE_URL=http://localhost:11434

# Embedding 配置（OpenAI 兼容接口）
# 使用云端 embedding 服务时，填 base_url + api_key；
# 使用本地 embedding 时，指向 LM Studio / Ollama / Xinference 等兼容接口。
# 未配置 EMBEDDING_API_KEY 时自动回退到 DummyEmbeddingFunction（md5 伪向量,仅接口联调,无语义检索能力）。
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
# 维度需与所选模型一致;云端 text-embedding-3-small=1536,本地 bge-large-zh-v1.5=1024。
# 留空时 DummyEmbedding 默认 384;切换真实模型后必须重建向量库（scripts/seed_kb.py --clear）。
EMBEDDING_DIMENSIONS=1536

# 向量库存储目录
VECTOR_STORE_DIR=./chroma_db

# 附件存储目录（路径遍历防护白名单根目录，附件文件仅允许在此目录内读取）
ATTACHMENT_DIR=./attachments

# 推理参数
TEMPERATURE=0.1
MAX_TOKENS=4096

# JWT 认证配置（生产环境必须修改 JWT_SECRET_KEY）
JWT_SECRET_KEY=change-this-to-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
# JWT claims 校验(可选,生产建议配置防 token 漂移到其他服务)
# JWT_AUDIENCE=agentvalue-api
# JWT_ISSUER=agentvalue-auth
# JWT_LEEWAY_SECONDS=30  # 时钟漂移容忍秒数

# CORS 允许来源(逗号分隔,生产环境必填实际域名,切勿留 *)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 视觉模型(用于 OCR Cloud 抽取图片文字,走 OpenAI vision API 兼容接口)
VISION_MODEL=gpt-4o-mini

# 演示模式：true 时允许通过 x-user-role / x-user-id header 伪造身份（仅开发/测试用）
# 生产环境必须设为 false
AUTH_DEMO_MODE=false

# 生产环境标识,设为 production 触发 demo_mode 守护(生产必须设)
# AGENTVALUE_ENV=production

# Langfuse 可观测性（可选）
LANGFUSE_PUBLIC_KEY=your-public-key
LANGFUSE_SECRET_KEY=your-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# 多模态配置（Phase 7.1）
# 注：OCR_CLOUD_API_KEY 统一在下方 Phase 10 云端 OCR/ASR 段定义（OpenAI 兼容 vision API），
# 此处仅保留 legacy aliyun/baidu 的 OCR_CLOUD_SECRET_KEY 字段。
OCR_PROVIDER=none
OCR_LANG=chi_sim+eng
OCR_CLOUD_PROVIDER=aliyun
OCR_CLOUD_SECRET_KEY=
ASR_PROVIDER=dummy
WHISPER_MODEL=base
MULTIMODAL_CONFIDENCE_THRESHOLD=0.7

# 对象存储 S3/MinIO（Phase 7.3，留空走本地 ATTACHMENT_DIR）
# 启用 MinIO 时填入你部署实例的真实凭据;下面注释行仅为字段示例,不是真实凭据。
# S3_ENDPOINT=minio:9000
# S3_ACCESS_KEY=your-minio-access-key
# S3_SECRET_KEY=your-minio-secret-key
# S3_BUCKET=agentvalue-attachments
# S3_SECURE=false

# 数据留存策略（Phase 9.3，GDPR/个保法）
RETENTION_RAW_INPUT_DAYS=730
RETENTION_EVALUATION_DAYS=1825
RETENTION_ARCHIVE_BUFFER_DAYS=30

# 字段级加密（生产必填，开发留空走明文透传）
# 用于 DB 中 manager_view/audit 敏感字段 AES-GCM 加密，DBA 直查 DB 仅见密文
# 生成方法: python -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
FIELD_ENCRYPTION_KEY=

# 云端 OCR/ASR（Phase 10 多模态真实接入，留空走本地 tesseract/DummyASR）
OCR_CLOUD_API_KEY=
OCR_CLOUD_BASE_URL=https://api.openai.com/v1
OCR_CLOUD_MODEL=gpt-4o-mini
ASR_CLOUD_API_KEY=
ASR_CLOUD_BASE_URL=https://api.openai.com/v1
ASR_CLOUD_MODEL=whisper-1

# 护栏误报率统计开关（true 时记 agentvalue_guard_checks_total / agentvalue_guard_false_positives_total）
GUARD_RAILS_METRICS_ENABLED=true

# ===== v2.1 新增配置 =====

# SSO 单点登录 (可选, 未配置时走默认 JWT 认证)
# SSO 配置通过 /api/v1/admin/sso/configs API 管理, 无需环境变量

# 文档解析 (可选, 未安装解析库时自动降级)
# pip install pdfplumber python-docx openpyxl python-pptx
# 文件解析根目录 (路径遍历防护白名单)
ATTACHMENT_DIR=./attachments

# NL2SQL (可选, 通过 /api/v1/admin/nl2sql API 管理)
# 允许查询的表白名单通过 /api/v1/admin/nl2sql/schemas API 管理

# 模型 Fallback (可选, 通过 /api/v1/admin/model-fallback API 管理)
# Fallback 链配置通过 API 管理, 无需环境变量

# 敏感词管理 (可选, 通过 /api/v1/admin/sensitive-words API 管理)
# AC 自动机依赖: pip install pyahocorasick
# 未安装时自动降级为简单字符串匹配

# LDAP (可选, SSO LDAP 认证时需要)
# pip install ldap3
# LDAP 配置通过 SSO API 管理

# 会话分析 / API 健康监控 (自动采集, 无需额外配置)
