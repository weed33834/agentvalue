# 版本控制
.git
.gitignore

# 依赖目录
**/node_modules
**/.venv
**/venv

# Python 缓存
**/__pycache__
**/*.pyc
**/*.pyo
**/.pytest_cache
**/*.egg-info

# 构建产物
**/dist
**/build

# 本地数据库与向量库（避免打包进镜像，运行时通过 volume 持久化）
**/*.db
**/*.db-shm
**/*.db-wal
**/chroma_db

# 环境与密钥
**/.env
**/.env.*
!**/.env.example

# 编辑器与系统文件
**/.vscode
**/.idea
**/.DS_Store

# 日志
**/*.log
**/logs

# 文档
**/*.md
docs/
